# Recompete AI — Railway env vars (set in Railway dashboard, not committed).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<paste service_role key from Supabase dashboard>

TELEGRAM_BOT_TOKEN=<paste bot token from BotFather>
TELEGRAM_CHAT_ID=<paste chat id>


# Optional knobs.
ALERT_WINDOW_DAYS=180     # flag contracts expiring within N days
DRY_RUN=false             # true = log + skip writes
