{
  "model": "opusplan",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Edit",
      "Write",
      "Read",

      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",

      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(sed:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(md5:*)",

      "Bash(npx tsc:*)",
      "Bash(npx playwright:*)",
      "Bash(npx tsx:*)",
      "Bash(node:*)",
      "Bash(npm run:*)",

      "Bash(cp:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",

      "Bash(curl:*)",

      "Bash(bash ~/faraudit-app/ceo/update-digest.sh:*)",
      "Bash(bash ~/faraudit-app/scripts/security/fort-knox-scan.sh:*)",

      "Bash(railway deployment list:*)",
      "Bash(railway logs:*)",
      "Bash(vercel inspect:*)",
      "Bash(vercel list:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)"
    ]
  }
}
