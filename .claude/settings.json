{
  "model": "opusplan",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Edit",
      "Write",
      "Read",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git stash list:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(sed:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(md5:*)",
      "Bash(jq:*)",
      "Bash(awk:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(diff:*)",
      "Bash(comm:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(pwd:*)",
      "Bash(env:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(npx tsc:*)",
      "Bash(npx playwright:*)",
      "Bash(npx tsx:*)",
      "Bash(node:*)",
      "Bash(npm run:*)",
      "Bash(cp:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(sleep:*)",
      "Bash(seq:*)",
      "Bash(test -f:*)",
      "Bash(test -d:*)",
      "Bash(curl:*)",
      "Bash(bash ~/faraudit-app/ceo/update-digest.sh:*)",
      "Bash(bash ~/faraudit-app/scripts/security/fort-knox-scan.sh:*)",
      "Bash(railway deployment list:*)",
      "Bash(railway logs:*)",
      "Bash(railway status:*)",
      "Bash(railway variables --kv:*)",
      "Bash(vercel inspect:*)",
      "Bash(vercel list:*)",
      "Bash(vercel ls:*)",
      "Bash(vercel logs:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)"
    ]
  }
}