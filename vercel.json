{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "src/app/api/audit/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/internal/watcher-tick/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/internal/watcher-tick",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/weekly-brief",
      "schedule": "0 13 * * 1"
    },
    {
      "path": "/api/cron/security-agent",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 12 * * 1-5"
    },
    {
      "path": "/api/cron/sales",
      "schedule": "30 12 * * 1-5"
    },
    {
      "path": "/api/cron/marketing",
      "schedule": "15 13 * * 1-5"
    },
    {
      "path": "/api/cron/digest",
      "schedule": "0 12 * * 1-5"
    },
    {
      "path": "/api/cron/digest",
      "schedule": "0 13 * * 0,6"
    }
  ]
}