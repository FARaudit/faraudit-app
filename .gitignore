# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# CEO tools — local only, never deploy to Vercel
ceo/
*.pdf

# OAuth bootstrap — script is tracked, but block any accidental token/secret files
scripts/oauth/*
!scripts/oauth/
!scripts/oauth/get-token.js

# Sync log artifacts (launchd output — never source)
scripts/sync-digest*.log

# Local test artifacts
outputs/
state-snapshot.txt
src/app/globals.css.bak-phase1
*.bak-*
src/app/sign-in/*.bak*
src/app/pricing/*.bak*
public/*.bak*
src/app/globals.css.bak*

# Playwright
e2e/.auth/
playwright-report/
test-results/
# e2e diagnostic probes (session-local, not part of the test suite)
e2e/tests/_diag-*.spec.ts
# local PDF verification artifacts (FA-130 era exports)
test/pdfs/
supabase/.temp/

.claude/worktrees/
